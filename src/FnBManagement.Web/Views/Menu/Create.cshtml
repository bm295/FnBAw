@model MenuItem

<section class="panel form-panel">
    <div class="page-heading">
        <div>
            <h2>Add Menu Item</h2>
            <p>Create a menu item with a category, price, and availability status.</p>
        </div>
        <a asp-action="Index">Back to menu</a>
    </div>

    <form class="editor-form" method="post" asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label asp-for="Name"></label>
        <input asp-for="Name" autocomplete="off" />
        <span asp-validation-for="Name" class="field-validation"></span>

        <label asp-for="Category"></label>
        <input asp-for="Category" autocomplete="off" />
        <span asp-validation-for="Category" class="field-validation"></span>

        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" min="0.01" step="0.01" />
        <span asp-validation-for="Price" class="field-validation"></span>

        <label class="checkbox-field">
            <input asp-for="IsAvailable" />
            <span>Available for ordering</span>
        </label>
        <span asp-validation-for="IsAvailable" class="field-validation"></span>

        <div class="form-actions">
            <button type="submit">Save menu item</button>
            <a asp-action="Index">Cancel</a>
        </div>
    </form>
</section>
