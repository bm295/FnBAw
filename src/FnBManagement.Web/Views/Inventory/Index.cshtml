@model IReadOnlyList<InventoryItem>

@{
    var searchTerm = ViewData["SearchTerm"] as string;
    var lowStockOnly = ViewData["LowStockOnly"] as bool? ?? false;
}

<section class="panel">
    <div class="page-heading">
        <div>
            <h2>Inventory</h2>
            <p>Search stock items, review current quantities, and focus on low-stock SKUs.</p>
        </div>
        <a class="button" asp-action="Create">Add inventory item</a>
    </div>

    <form class="filter-bar" method="get" asp-action="Index">
        <label>
            Search
            <input type="search" name="searchTerm" value="@searchTerm" placeholder="Search by item name" />
        </label>
        <label class="checkbox-field">
            @if (lowStockOnly)
            {
                <input type="checkbox" name="lowStockOnly" value="true" checked />
            }
            else
            {
                <input type="checkbox" name="lowStockOnly" value="true" />
            }
            <span>Low-stock items only</span>
        </label>
        <button type="submit">Apply filters</button>
        <a asp-action="Index">Clear</a>
    </form>

    @if (Model.Count == 0)
    {
        <p class="empty-state">No inventory items match the current filters.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Quantity</th>
                    <th>Unit</th>
                    <th>Reorder level</th>
                    <th>Status</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inventoryItem in Model)
                {
                    <tr>
                        <td>@inventoryItem.Name</td>
                        <td>@inventoryItem.QuantityInStock.ToString("N2")</td>
                        <td>@inventoryItem.Unit</td>
                        <td>@inventoryItem.ReorderLevel.ToString("N2")</td>
                        <td>@(inventoryItem.IsLowStock ? "Low stock" : "In stock")</td>
                        <td class="actions-column">
                            <a asp-action="Edit" asp-route-id="@inventoryItem.Id">Edit</a>
                            <a asp-action="AdjustStock" asp-route-id="@inventoryItem.Id">Adjust stock</a>
                            @if (inventoryItem.IsLowStock)
                            {
                                <form method="post" asp-action="Reorder" asp-route-id="@inventoryItem.Id">
                                    <input type="hidden" name="quantity" value="@(inventoryItem.ReorderLevel - inventoryItem.QuantityInStock + 1)" />
                                    <button type="submit">Reorder</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
